# ─────────────────────────────────────────────────────────────
# FinPilot — environment template.  Copy to `.env` and fill in.
# NEVER commit the real `.env`.  No secrets in code, ever.
# ─────────────────────────────────────────────────────────────

# --- Core ---
ENVIRONMENT=development          # development | staging | production
PROJECT_NAME=FinPilot
TZ=Asia/Kolkata

# --- Database (Postgres + TimescaleDB + pgvector) ---
POSTGRES_USER=finpilot
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=finpilot
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Async SQLAlchemy URL used by the backend
DATABASE_URL=postgresql+asyncpg://finpilot:change_me_strong_password@db:5432/finpilot

# --- Redis (cache, pub/sub, rate-limit, Celery broker) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Auth / JWT (generate with: openssl rand -hex 32) ---
JWT_SECRET_KEY=change_me_min_256_bit_random_hex
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- OAuth2 Google ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# --- Market data (free tiers) ---
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=
# yfinance needs no key

# --- LLM / RAG (optional; local model supported) ---
OPENAI_API_KEY=
HUGGINGFACE_TOKEN=
EMBEDDING_MODEL=text-embedding-3-small

# --- Email (budget/fraud alerts) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=alerts@finpilot.local

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# --- CORS (comma-separated allow-list) ---
CORS_ORIGINS=http://localhost:3000
